{
  "name": "leadflow-backend",
  "version": "1.0.0",
  "description": "LeadFlow backend API — Node.js + Express",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node src/seed.js",
    "test": "jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./src/__tests__/setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "jest": "^30.4.1",
    "supertest": "^7.2.2"
  }
}
